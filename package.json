{
  "name": "chet-bot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on tcp:5173 dist-electron/main.js && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electronmon .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.electron.json && tsc -p tsconfig.json --noEmit",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.18.1",
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.3.0",
    "electronmon": "^2.0.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^8.0.5"
  }
}
