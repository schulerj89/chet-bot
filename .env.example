OPENAI_API_KEY=your_openai_api_key_here
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
OPENAI_THINKING_MODEL=gpt-5.2
OPENAI_THINKING_USE_WEB_SEARCH=false
OPENAI_THINKING_MAX_INPUT_TOKENS=2000
OPENAI_THINKING_MAX_OUTPUT_TOKENS=2000
OPENAI_TASK_PLANNER_MAX_INPUT_TOKENS=2000
OPENAI_TASK_PLANNER_MAX_OUTPUT_TOKENS=2000
CHET_APPROVAL_MODE=always
CHET_TASK_MAX_STEPS=5
